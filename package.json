{
  "name": "pdf-approval",
  "version": "0.9.2",
  "description": "LAN PDF drawing approval system for Windows teams",
  "author": "PDF Approval Team",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "tsc && vite build",
    "e2e:server": "tsx e2e/support/server.ts",
    "e2e:client": "vite --host 127.0.0.1 --port 14173 --strictPort",
    "e2e:ui:client": "vite --host 127.0.0.1 --port 34173 --strictPort",
    "e2e:typecheck": "tsc -p tsconfig.e2e.json",
    "e2e": "playwright test",
    "e2e:platform": "node scripts/run-platform-e2e.mjs",
    "e2e:ui": "node scripts/run-ui-gallery-e2e.mjs",
    "e2e:platform:server": "node --env-file=infra/local/.env.example --import tsx e2e/platform/support/server.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:update": "playwright test --update-snapshots=all",
    "infra:up": "node scripts/platform-deps.mjs up",
    "infra:down": "node scripts/platform-deps.mjs down",
    "infra:status": "node scripts/platform-deps.mjs status",
    "platform:db:migrate": "node --env-file=infra/local/.env.example --import tsx src/server/platform/database/migrateCli.ts",
    "platform:worker": "node --env-file=infra/local/.env.example --import tsx src/server/platform/jobs/workerMain.ts",
    "platform:bootstrap-admin": "node --env-file=infra/local/.env.example --import tsx src/server/commands/bootstrapAdmin.ts",
    "platform:jobs": "node --env-file=infra/local/.env.example --import tsx src/server/platform/jobs/jobDiagnosticsCli.ts",
    "migration:legacy:inventory": "node --import tsx scripts/migrate/legacyInventoryCli.ts",
    "migration:legacy:snapshot": "node --import tsx scripts/migrate/legacySnapshotCli.ts",
    "migration:legacy:files": "node --import tsx scripts/migrate/legacyFilePreflightCli.ts",
    "migration:legacy:run": "node --import tsx src/server/platform/migration/legacyMigrationCli.ts",
    "test:platform:unit": "node scripts/run-with-timeout.mjs 60000 npm test -- --run src/server/platform src/server/modules/identity src/shared/contracts",
    "test:platform:integration": "node scripts/run-with-timeout.mjs 180000 node --env-file=infra/local/.env.example node_modules/vitest/vitest.mjs run --config vitest.platform.integration.config.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "icons:generate": "node scripts/generateAppIcons.mjs",
    "tray:dev": "npm --prefix apps/tray-helper run tauri dev",
    "tray:build": "npm --prefix apps/tray-helper run tauri build",
    "tray:test": "npm --prefix apps/tray-helper test",
    "desktop:dev": "electron apps/desktop-client",
    "desktop:test": "vitest run --config apps/desktop-client/vitest.config.mjs",
    "desktop:build": "npm run build && npm run desktop:test",
    "desktop:package": "npm run build && npm run desktop:test && node scripts/desktopPackage.mjs",
    "server:package": "npm run build && npm test -- --run src/server/serverPackage.test.ts && node scripts/serverPackage.mjs",
    "server:exe": "npm run build && npm test -- --run src/server/serverExePackage.test.ts && node scripts/serverExePackage.mjs",
    "installer:test": "npm test -- --run src/server/windowsInstallers.test.ts",
    "release:manifest": "node scripts/createUpdateManifest.mjs",
    "release:sync-runtime": "node scripts/syncRuntimeRelease.mjs",
    "installer:package": "npm run build && npm run desktop:test && npm run installer:test && node scripts/desktopPackage.mjs && node scripts/serverExePackage.mjs && node scripts/windowsInstallers.mjs && node scripts/createUpdateManifest.mjs && node scripts/syncRuntimeRelease.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1084.0",
    "@inquirer/prompts": "^8.5.2",
    "@node-rs/argon2": "^2.0.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "bcryptjs": "^2.4.3",
    "chokidar": "^4.0.3",
    "cookie-parser": "^1.4.7",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "ipaddr.js": "^2.4.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.21.0",
    "nodemailer": "^9.0.1",
    "otpauth": "^9.5.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.23.1",
    "uuid": "^14.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  }
}
