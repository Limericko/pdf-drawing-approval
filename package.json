{
  "name": "pdf-approval",
  "version": "0.9.2",
  "description": "LAN PDF drawing approval system for Windows teams",
  "author": "PDF Approval Team",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-server.mjs",
    "build": "tsc && vite build",
    "e2e:server": "tsx e2e/support/server.ts",
    "e2e:client": "vite --host 127.0.0.1 --port 14173 --strictPort",
    "e2e:typecheck": "tsc -p tsconfig.e2e.json",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:update": "playwright test --update-snapshots=all",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "icons:generate": "node scripts/generateAppIcons.mjs",
    "tray:dev": "npm --prefix apps/tray-helper run tauri dev",
    "tray:build": "npm --prefix apps/tray-helper run tauri build",
    "tray:test": "npm --prefix apps/tray-helper test",
    "desktop:dev": "electron apps/desktop-client",
    "desktop:test": "vitest run --config apps/desktop-client/vitest.config.mjs",
    "desktop:build": "npm run build && npm run desktop:test",
    "desktop:package": "npm run build && npm run desktop:test && node scripts/desktopPackage.mjs",
    "server:package": "npm run build && npm test -- --run src/server/serverPackage.test.ts && node scripts/serverPackage.mjs",
    "server:exe": "npm run build && npm test -- --run src/server/serverExePackage.test.ts && node scripts/serverExePackage.mjs",
    "installer:test": "npm test -- --run src/server/windowsInstallers.test.ts",
    "release:manifest": "node scripts/createUpdateManifest.mjs",
    "release:sync-runtime": "node scripts/syncRuntimeRelease.mjs",
    "installer:package": "npm run build && npm run desktop:test && npm run installer:test && node scripts/desktopPackage.mjs && node scripts/serverExePackage.mjs && node scripts/windowsInstallers.mjs && node scripts/createUpdateManifest.mjs && node scripts/syncRuntimeRelease.mjs"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "bcryptjs": "^2.4.3",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.21.0",
    "nodemailer": "^9.0.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  }
}
