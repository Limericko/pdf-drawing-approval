{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF 图纸审批托盘助手",
  "version": "0.1.0",
  "identifier": "local.pdf-approval.tray-helper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PDF 图纸审批托盘助手",
        "width": 420,
        "height": 480,
        "resizable": false
      }
    ],
    "trayIcon": {
      "id": "pdf-approval-tray",
      "iconPath": "icons/32x32.png",
      "showMenuOnLeftClick": true,
      "tooltip": "PDF 图纸审批托盘助手"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "PDF Approval Team",
    "category": "Business",
    "shortDescription": "PDF 图纸审批托盘助手",
    "longDescription": "局域网 PDF 图纸审批系统的 Windows 托盘提醒助手。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
