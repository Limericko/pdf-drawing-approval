COMPOSE_PROJECT_NAME=pdf-approval-single-node
PDF_APPROVAL_IMAGE=ghcr.io/limericko/pdf-drawing-approval:0.9.2-refactor
PDF_APPROVAL_DOMAIN=approval.example.com
PDF_APPROVAL_BIND_ADDRESS=127.0.0.1
PDF_APPROVAL_HTTP_PORT=18080
PDF_APPROVAL_SMTP_HOST=smtp.example.com
PDF_APPROVAL_SMTP_PORT=465
PDF_APPROVAL_SMTP_FROM=approval@example.com
PDF_APPROVAL_SMTP_SECURE=true
PDF_APPROVAL_SMTP_REQUIRE_TLS=false
PDF_APPROVAL_SMTP_USER=approval@example.com
PDF_APPROVAL_WEBDAV_ALLOWED_HOSTS=
PDF_APPROVAL_WEB_DB_POOL_MAX=20
PDF_APPROVAL_WORKER_DB_POOL_MAX=8
PDF_APPROVAL_WORKER_CONCURRENCY=4
