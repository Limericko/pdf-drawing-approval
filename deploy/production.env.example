PDF_APPROVAL_IMAGE=registry.example.com/pdf-approval@sha256:replace-with-immutable-digest
PDF_APPROVAL_PUBLIC_BASE_URL=https://approval.example.com
PDF_APPROVAL_STORAGE_S3_ENDPOINT=https://s3.provider.example
PDF_APPROVAL_STORAGE_S3_REGION=replace-provider-region
PDF_APPROVAL_STORAGE_S3_BUCKET=replace-private-bucket
PDF_APPROVAL_STORAGE_S3_FORCE_PATH_STYLE=false
PDF_APPROVAL_STORAGE_S3_ALLOWED_HOSTS=s3.provider.example
PDF_APPROVAL_WEBDAV_ALLOWED_HOSTS=dav.example.com

PDF_APPROVAL_SMTP_HOST=smtp.example.com
PDF_APPROVAL_SMTP_PORT=465
PDF_APPROVAL_SMTP_FROM=approval@example.com
PDF_APPROVAL_SMTP_SECURE=true
PDF_APPROVAL_SMTP_REQUIRE_TLS=false
PDF_APPROVAL_SMTP_USER=replace-smtp-user

PDF_APPROVAL_WEB_SECRET_DIR=/run/pdf-approval-secrets/web
PDF_APPROVAL_WORKER_SECRET_DIR=/run/pdf-approval-secrets/worker
PDF_APPROVAL_MIGRATION_SECRET_DIR=/run/pdf-approval-secrets/migration
PDF_APPROVAL_BOOTSTRAP_SECRET_DIR=/run/pdf-approval-secrets/bootstrap

PDF_APPROVAL_WEB_DB_POOL_MAX=20
PDF_APPROVAL_WORKER_DB_POOL_MAX=8
PDF_APPROVAL_WORKER_CONCURRENCY=4
